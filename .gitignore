# ----------------------------------------
# Python & FastAPI Project .gitignore
# ----------------------------------------

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
.eggs/
wheels/
share/python-wheels/
MANIFEST

# PyInstaller
*.spec
*.manifest

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit testing / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Databases
*.db
*.sqlite3
*.sqlite3-journal

# Django/Flask common log files
*.log

# Streamlit cache
.streamlit/

# Scrapy
.scrapy/

# Sphinx docs
docs/_build/

# PyBuilder
target/

# Jupyter Notebook
.ipynb_checkpoints/

# IPython
profile_default/
ipython_config.py

# Virtual Environments
.env
.env.*
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# Pyenv
.python-version

# Poetry / PDM / UV
.pdm.toml
.pdm-python
.pdm-build/
__pypackages__/
# uv.lock is usually kept, but ignore if you prefer
.uv/
uv.lock

# Celery
celerybeat-schedule
celerybeat.pid

# mypy
.mypy_cache/

# pytype
.pytype/

# Cython debug
cython_debug/

# Cursor editor
.cursorignore
.cursorindexingignore

# LangChain / RAG cache
cache/

# OS / Editor
.DS_Store
.vscode/
.idea/

# Build artifacts
/site/

# Vector DB / Semantic cache
cache_db/
semantic_cache/
vector_cache/
db_cache/
*.lance
*.arrow
*.snappy
*.idx
*.npy
*.pkl
*.parquet
chroma/
chroma_db/
chromadb/